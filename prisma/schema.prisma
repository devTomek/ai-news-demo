generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  content   String
  category  String
  readTime  Int
  imageUrl  String
  imageAlt  String
  sources   Json     @default("[]")
  createdAt DateTime @default(now())
}
